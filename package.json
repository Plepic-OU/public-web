  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "htmlhint": "^1.9.1",
    "husky": "^9.1.0",
    "serve": "^14.2.0",
    "stylelint": "^17.2.0",
    "stylelint-config-standard": "^40.0.0"
  }
