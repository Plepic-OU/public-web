    "doc": "docs"
  },
  "scripts": {
    "test": "npm run lint && npm run test:visual",
    "lint:html": "htmlhint '*.html' 'agent/*.html' 'training/*.html'",
    "lint:css": "stylelint 'css/*.css'",
    "lint": "npm run lint:html && npm run lint:css",
    "test:visual": "playwright test --config=playwright.visual.config.ts",
    "test:visual:update": "playwright test --config=playwright.visual.config.ts --update-snapshots",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Plepic-OU/public-web.git"
  },
